<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#417E3E"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Splash">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="500dp"
        android:src="@drawable/soko"
        android:scaleType="centerCrop"

        />
    
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to Sokogarden — your smart and simple way to connect with fresh, healthy produce right at your fingertips."
        android:fontFamily="times"
        android:layout_marginTop="20sp"
        android:textSize="20dp"
        android:textColor="#F00606"

        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Developed by Alvin"
        android:fontFamily="cursive"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginTop="90sp"
        android:textColor="#000000"
        />


</LinearLayout>